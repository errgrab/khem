{
  "name": "khem",
  "version": "1.0.0",
  "description": "A homoiconic, DOM-compiling scripting language.",
  "main": "src/index.js",
  "directories": {
    "example": "examples"
  },
  "scripts": {
    "build": "esbuild src/index.js --bundle --format=esm --outfile=khem.js --minify",
    "test": "node tests/parser_test.js && node tests/stdlib_test.js && node tests/web_test.js",
    "repl": "node bin/khem.js repl",
    "watch": "node bin/khem.js watch",
    "serve": "node bin/khem.js serve"
  },
  "bin": {
    "khem": "./bin/khem.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/errgrab/khem.git"
  },
  "keywords": [],
  "author": "ErikG",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/errgrab/khem/issues"
  },
  "homepage": "https://github.com/errgrab/khem#readme",
  "devDependencies": {
    "esbuild": "^0.27.4"
  }
}
