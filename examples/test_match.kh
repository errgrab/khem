# test_match.kh — Pattern matching test
# Uses evaluator path (no state) so match works

proc testMatch { op } {
  match $op {
    "+" { text "Matched +" }
    "-" { text "Matched -" }
    default { text "No match" }
  }
}

div { class "app";
  h2 { text "Pattern Matching" };
  p { text [testMatch "+"] };
  p { text [testMatch "-"] };
  p { text [testMatch "x"] }
}

style {
  .app { padding 2rem; max-width 400px }
  h2 { font-family var(--serif); font-size 20px; margin-bottom 12px }
  p { margin 4px 0; color var(--fg1) }
}
