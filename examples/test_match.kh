# test_match.kh — Debug match command

proc testMatch { op } {
  match $op {
    "+" { text "Matched +" }
    "-" { text "Matched -" }
    default { text "No match" }
  }
}

div { class "app";
  p { text [testMatch "+"] };
  p { text [testMatch "-"] };
  p { text [testMatch "x"] }
}

style {
  .app { padding 2rem; font-size 14px }
  p { margin 4px 0 }
}
