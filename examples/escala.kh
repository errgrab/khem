      if "$shiftIdx" "0" { span { class "cell cell-0"; on_click { set d28 expr "(Number($d28)===0||Number($d28)===70)?76:Number($d28)===76?78:70" }; text "28" } } else { if "$shiftIdx" "76" { span { class "cell cell-1"; on_click { set d28 expr "(Number($d28)===0||Number($d28)===70)?76:Number($d28)===76?78:70" }; text "L" } } else { if "$shiftIdx" "78" { span { class "cell cell-2"; on_click { set d28 expr "(Number($d28)===0||Number($d28)===70)?76:Number($d28)===76?78:70" }; text "N" } } else { span { class "cell cell-3"; on_click { set d28 expr "(Number($d28)===0||Number($d28)===70)?76:Number($d28)===76?78:70" }; text "F" } } } };
      set shiftIdx expr "Number($d29)";
      if "$shiftIdx" "0" { span { class "cell cell-0"; on_click { set d29 expr "(Number($d29)===0||Number($d29)===70)?76:Number($d29)===76?78:70" }; text "29" } } else { if "$shiftIdx" "76" { span { class "cell cell-1"; on_click { set d29 expr "(Number($d29)===0||Number($d29)===70)?76:Number($d29)===76?78:70" }; text "L" } } else { if "$shiftIdx" "78" { span { class "cell cell-2"; on_click { set d29 expr "(Number($d29)===0||Number($d29)===70)?76:Number($d29)===76?78:70" }; text "N" } } else { span { class "cell cell-3"; on_click { set d29 expr "(Number($d29)===0||Number($d29)===70)?76:Number($d29)===76?78:70" }; text "F" } } } };
      set shiftIdx expr "Number($d30)";
      if "$shiftIdx" "0" { span { class "cell cell-0"; on_click { set d30 expr "(Number($d30)===0||Number($d30)===70)?76:Number($d30)===76?78:70" }; text "30" } } else { if "$shiftIdx" "76" { span { class "cell cell-1"; on_click { set d30 expr "(Number($d30)===0||Number($d30)===70)?76:Number($d30)===76?78:70" }; text "L" } } else { if "$shiftIdx" "78" { span { class "cell cell-2"; on_click { set d30 expr "(Number($d30)===0||Number($d30)===70)?76:Number($d30)===76?78:70" }; text "N" } } else { span { class "cell cell-3"; on_click { set d30 expr "(Number($d30)===0||Number($d30)===70)?76:Number($d30)===76?78:70" }; text "F" } } } };
      set shiftIdx expr "Number($d31)";
      if "$shiftIdx" "0" { span { class "cell cell-0"; on_click { set d31 expr "(Number($d31)===0||Number($d31)===70)?76:Number($d31)===76?78:70" }; text "31" } } else { if "$shiftIdx" "76" { span { class "cell cell-1"; on_click { set d31 expr "(Number($d31)===0||Number($d31)===70)?76:Number($d31)===76?78:70" }; text "L" } } else { if "$shiftIdx" "78" { span { class "cell cell-2"; on_click { set d31 expr "(Number($d31)===0||Number($d31)===70)?76:Number($d31)===76?78:70" }; text "N" } } else { span { class "cell cell-3"; on_click { set d31 expr "(Number($d31)===0||Number($d31)===70)?76:Number($d31)===76?78:70" }; text "F" } } } };

    }
  };
  div { class "legend";
    span { class "leg-item"; span { class "leg-dot leg-1"; text " " }; span { class "leg-text"; text "L194  08–16" } };
    span { class "leg-item"; span { class "leg-dot leg-2"; text " " }; span { class "leg-text"; text "N220  16–00" } };
    span { class "leg-item"; span { class "leg-dot leg-3"; text " " }; span { class "leg-text"; text "Folga" } }
  };
  div { class "stats";
    div { class "stats-title"; text "Resumo" };
    set shiftIdx expr "(Number($d1)===76?1:0)+(Number($d2)===76?1:0)+(Number($d3)===76?1:0)+(Number($d4)===76?1:0)+(Number($d5)===76?1:0)+(Number($d6)===76?1:0)+(Number($d7)===76?1:0)+(Number($d8)===76?1:0)+(Number($d9)===76?1:0)+(Number($d10)===76?1:0)+(Number($d11)===76?1:0)+(Number($d12)===76?1:0)+(Number($d13)===76?1:0)+(Number($d14)===76?1:0)+(Number($d15)===76?1:0)+(Number($d16)===76?1:0)+(Number($d17)===76?1:0)+(Number($d18)===76?1:0)+(Number($d19)===76?1:0)+(Number($d20)===76?1:0)+(Number($d21)===76?1:0)+(Number($d22)===76?1:0)+(Number($d23)===76?1:0)+(Number($d24)===76?1:0)+(Number($d25)===76?1:0)+(Number($d26)===76?1:0)+(Number($d27)===76?1:0)+(Number($d28)===76?1:0)+(Number($d29)===76?1:0)+(Number($d30)===76?1:0)+(Number($d31)===76?1:0)";
    if "$shiftIdx" "0" { div { class "stat-row"; span { class "stat-label stat-1"; text "L194" }; span { class "stat-value"; text "$shiftIdx" } } };
    set shiftIdx expr "(Number($d1)===78?1:0)+(Number($d2)===78?1:0)+(Number($d3)===78?1:0)+(Number($d4)===78?1:0)+(Number($d5)===78?1:0)+(Number($d6)===78?1:0)+(Number($d7)===78?1:0)+(Number($d8)===78?1:0)+(Number($d9)===78?1:0)+(Number($d10)===78?1:0)+(Number($d11)===78?1:0)+(Number($d12)===78?1:0)+(Number($d13)===78?1:0)+(Number($d14)===78?1:0)+(Number($d15)===78?1:0)+(Number($d16)===78?1:0)+(Number($d17)===78?1:0)+(Number($d18)===78?1:0)+(Number($d19)===78?1:0)+(Number($d20)===78?1:0)+(Number($d21)===78?1:0)+(Number($d22)===78?1:0)+(Number($d23)===78?1:0)+(Number($d24)===78?1:0)+(Number($d25)===78?1:0)+(Number($d26)===78?1:0)+(Number($d27)===78?1:0)+(Number($d28)===78?1:0)+(Number($d29)===78?1:0)+(Number($d30)===78?1:0)+(Number($d31)===78?1:0)";
    if "$shiftIdx" "0" { div { class "stat-row"; span { class "stat-label stat-2"; text "N220" }; span { class "stat-value"; text "$shiftIdx" } } };
    set shiftIdx expr "(Number($d1)===70?1:0)+(Number($d2)===70?1:0)+(Number($d3)===70?1:0)+(Number($d4)===70?1:0)+(Number($d5)===70?1:0)+(Number($d6)===70?1:0)+(Number($d7)===70?1:0)+(Number($d8)===70?1:0)+(Number($d9)===70?1:0)+(Number($d10)===70?1:0)+(Number($d11)===70?1:0)+(Number($d12)===70?1:0)+(Number($d13)===70?1:0)+(Number($d14)===70?1:0)+(Number($d15)===70?1:0)+(Number($d16)===70?1:0)+(Number($d17)===70?1:0)+(Number($d18)===70?1:0)+(Number($d19)===70?1:0)+(Number($d20)===70?1:0)+(Number($d21)===70?1:0)+(Number($d22)===70?1:0)+(Number($d23)===70?1:0)+(Number($d24)===70?1:0)+(Number($d25)===70?1:0)+(Number($d26)===70?1:0)+(Number($d27)===70?1:0)+(Number($d28)===70?1:0)+(Number($d29)===70?1:0)+(Number($d30)===70?1:0)+(Number($d31)===70?1:0)";
    if "$shiftIdx" "0" { div { class "stat-row"; span { class "stat-label stat-3"; text "Folga" }; span { class "stat-value"; text "$shiftIdx" } } }
  }
}

style {
  .app {
    max-width 420px
    margin 40px auto
    display flex
    flex-direction column
    gap 20px
  }
  .header {
    display flex
    flex-direction column
    gap 2px
    padding-bottom 16px
    border-bottom 1px solid var(--border)
  }
  .logo {
    font-family var(--serif)
    font-size 28px
    color var(--fg)
  }
  .sub {
    font-size 9.5px
    text-transform uppercase
    letter-spacing 0.12em
    color var(--fg3)
  }
  .nav {
    display flex
    align-items center
    justify-content space-between
    gap 12px
  }
  .nav-btn {
    background var(--s1)
    border 1px solid var(--border)
    color var(--fg2)
    padding 6px 14px
    cursor pointer
    font-size 14px
    font-family inherit
    transition all 0.15s
  }
  .nav-btn:hover {
    background var(--s2)
    border-color var(--b2)
    color var(--fg)
  }
  .nav-label {
    font-family var(--serif)
    font-size 16px
    color var(--fg1)
  }
  .cal {
    border 1px solid var(--border)
    background var(--s0)
    overflow hidden
  }
  .weekdays {
    display grid
    grid-template-columns repeat(7, 1fr)
    border-bottom 1px solid var(--b2)
    background var(--s1)
  }
  .wd {
    text-align center
    padding 8px 4px
    font-size 8.5px
    text-transform uppercase
    letter-spacing 0.12em
    color var(--fg3)
  }
  .grid {
    display grid
    grid-template-columns repeat(7, 1fr)
    gap 1px
    background var(--border)
  }
  .cell {
    aspect-ratio 1
    display flex
    align-items center
    justify-content center
    font-size 11px
    cursor pointer
    transition all 0.12s
    background var(--s0)
    min-height 42px
    user-select none
  }
  .cell:hover {
    background var(--s2)
  }
  .cell-0 {
    color var(--fg3)
    font-size 10px
  }
  .cell-1 {
    background var(--green-dim)
    color var(--green)
    font-weight bold
    font-size 13px
  }
  .cell-1:hover { background #345e3d }
  .cell-2 {
    background var(--blue-dim)
    color var(--blue)
    font-weight bold
    font-size 13px
  }
  .cell-2:hover { background #354e63 }
  .cell-3 {
    background var(--red-dim)
    color var(--red)
    font-weight bold
    font-size 13px
  }
  .cell-3:hover { background #5a2e2e }
  .legend {
    display flex
    gap 20px
    justify-content center
    padding 12px 0 4px 0
  }
  .leg-item {
    display flex
    align-items center
    gap 6px
  }
  .leg-dot {
    width 10px
    height 10px
    border-radius 2px
    display inline-block
  }
  .leg-1 { background var(--green) }
  .leg-2 { background var(--blue) }
  .leg-3 { background var(--red) }
  .leg-text {
    font-size 9.5px
    color var(--fg2)
    letter-spacing 0.04em
  }
  .stats {
    display flex
    flex-direction column
    gap 6px
    padding 16px 0 0 0
    border-top 1px solid var(--border)
  }
  .stats-title {
    font-size 9.5px
    text-transform uppercase
    letter-spacing 0.12em
    color var(--dim)
    margin-bottom 4px
  }
  .stat-row {
    display flex
    justify-content space-between
    align-items baseline
    padding 4px 0
  }
  .stat-label {
    font-size 10px
    text-transform uppercase
    letter-spacing 0.08em
  }
  .stat-1 { color var(--green) }
  .stat-2 { color var(--blue) }
  .stat-3 { color var(--red) }
  .stat-value {
    font-family var(--serif)
    font-size 20px
    color var(--fg)
  }
}
