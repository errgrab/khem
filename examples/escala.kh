      if "$shiftIdx" "0" { span { class "cell cell-0"; on_click { set d3 expr "(Number($d3)===0||Number($d3)===70)?76:Number($d3)===76?78:70" }; text "3" } } else { if "$shiftIdx" "76" { span { class "cell cell-1"; on_click { set d3 expr "(Number($d3)===0||Number($d3)===70)?76:Number($d3)===76?78:70" }; text "L" } } else { if "$shiftIdx" "78" { span { class "cell cell-2"; on_click { set d3 expr "(Number($d3)===0||Number($d3)===70)?76:Number($d3)===76?78:70" }; text "N" } } else { span { class "cell cell-3"; on_click { set d3 expr "(Number($d3)===0||Number($d3)===70)?76:Number($d3)===76?78:70" }; text "F" } } } };
