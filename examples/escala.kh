# escala.kh — Shift Calendar / Escala de Trabalho
# Click cycles: empty → L194 → N220 → F(folga) → empty
# CharCodes: 0=empty, 76=L, 78=N, 70=F

state month "4"
state year "2026"
state dim "30"
state shiftIdx "0"

# Per-day shift type (charCode: 0=empty, 76=L194, 78=N220, 70=Folga)
state d1 "0"; state d2 "0"; state d3 "0"; state d4 "0"; state d5 "0"
state d6 "0"; state d7 "0"; state d8 "0"; state d9 "0"; state d10 "0"
state d11 "0"; state d12 "0"; state d13 "0"; state d14 "0"; state d15 "0"
state d16 "0"; state d17 "0"; state d18 "0"; state d19 "0"; state d20 "0"
state d21 "0"; state d22 "0"; state d23 "0"; state d24 "0"; state d25 "0"
state d26 "0"; state d27 "0"; state d28 "0"; state d29 "0"; state d30 "0"
state d31 "0"

div { class "app";
  div { class "header";
    span { class "logo"; text "Escala" };
    span { class "sub"; text "Calendário de Turnos" }
  };
  div { class "nav";
    button { class "nav-btn"; text "◂"; on_click {
      set month expr "(($month - 2 + 12) % 12) + 1";
      set dim expr "Number($month)===2?((!((Number($year)%4===0)&&(Number($year)%100!==0||Number($year)%400===0)))?28:29):Number($month)===4||Number($month)===6||Number($month)===9||Number($month)===11?30:31"
    } };
    span { class "nav-label"; text "Abr $year" };
    button { class "nav-btn"; text "▸"; on_click {
      set month expr "($month % 12) + 1";
      set dim expr "Number($month)===2?((!((Number($year)%4===0)&&(Number($year)%100!==0||Number($year)%400===0)))?28:29):Number($month)===4||Number($month)===6||Number($month)===9||Number($month)===11?30:31"
    } }
  };
  div { class "cal";
    div { class "weekdays";
      div { class "wd"; text "DOM" };
      div { class "wd"; text "SEG" };
      div { class "wd"; text "TER" };
      div { class "wd"; text "QUA" };
      div { class "wd"; text "QUI" };
      div { class "wd"; text "SEX" };
      div { class "wd"; text "SÁB" }
    };
    div { class "grid";
      set shiftIdx expr "Number($d1)";
      if "$shiftIdx" "0" { span { class "cell cell-0"; on_click { set d1 expr "(Number($d1)===0||Number($d1)===70)?76:Number($d1)===76?78:70" }; text "1" } } else { if "$shiftIdx" "76" { span { class "cell cell-1"; on_click { set d1 expr "(Number($d1)===0||Number($d1)===70)?76:Number($d1)===76?78:70" }; text "L" } } else { if "$shiftIdx" "78" { span { class "cell cell-2"; on_click { set d1 expr "(Number($d1)===0||Number($d1)===70)?76:Number($d1)===76?78:70" }; text "N" } } else { span { class "cell cell-3"; on_click { set d1 expr "(Number($d1)===0||Number($d1)===70)?76:Number($d1)===76?78:70" }; text "F" } } } };
      set shiftIdx expr "Number($d2)";
      if "$shiftIdx" "0" { span { class "cell cell-0"; on_click { set d2 expr "(Number($d2)===0||Number($d2)===70)?76:Number($d2)===76?78:70" }; text "2" } } else { if "$shiftIdx" "76" { span { class "cell cell-1"; on_click { set d2 expr "(Number($d2)===0||Number($d2)===70)?76:Number($d2)===76?78:70" }; text "L" } } else { if "$shiftIdx" "78" { span { class "cell cell-2"; on_click { set d2 expr "(Number($d2)===0||Number($d2)===70)?76:Number($d2)===76?78:70" }; text "N" } } else { span { class "cell cell-3"; on_click { set d2 expr "(Number($d2)===0||Number($d2)===70)?76:Number($d2)===76?78:70" }; text "F" } } } };
